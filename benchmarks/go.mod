// Module quarkbench is a standalone benchmark harness for Quark.
//
// It lives in its own module so the comparison dependencies (GORM, the
// pure-Go SQLite driver) never leak into the library's go.mod. The
// library is consumed through a local replace directive.
module github.com/jcsvwinston/quark/benchmarks

go 1.25.7

toolchain go1.26.5

require (
	entgo.io/ent v0.14.6
	github.com/glebarez/sqlite v1.11.0
	github.com/jcsvwinston/quark v0.10.0
	gorm.io/gorm v1.31.0
	modernc.org/sqlite v1.23.1
)

require (
	ariga.io/atlas v0.36.2-0.20250730182955-2c6300d0a3e1 // indirect
